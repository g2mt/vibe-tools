#!/usr/bin/python3
import os
import sys
import argparse
import subprocess
import yaml

ANSI_GRAY = "\033[90m"
ANSI_RESET ="\033[0m"
ANSI_BOLD = "\033[1m"

class Subtree:
    def __init__(self, path, url, branch='master'):
        self.path = path
        self.url = url
        self.branch = branch

    def get_squash_cmd(self, action):
        return ["git","subtree",action,"--prefix",self.path,self.url,self.branch,"--squash"]

class Program:
    def __init__(self, args):
        self.args = args

    def get_repo_root(self):
        result = subprocess.run(
            ['git', 'rev-parse', '--show-toplevel'],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()

    def load_gitsubtrees(self, repo_root):
        path = os.path.join(repo_root, '.gitsubtrees')
        if not os.path.exists(path):
            return []
        with open(path, 'r') as f:
            data = yaml.safe_load(f)
            if data is None:
                return []
            if not isinstance(data, list):
                raise ValueError(f".gitsubtrees file must contain a list, got {type(data).__name__}")
            entries = []
            for entry in data:
                if not isinstance(entry, dict):
                    raise ValueError(f"Each entry must be a mapping, got {type(entry).__name__}: {entry}")
                if 'path' not in entry or 'url' not in entry:
                    raise ValueError(f"Each entry must have 'path' and 'url' keys, got {entry}")
                e = Subtree(
                    path=entry['path'],
                    url=entry['url'],
                    branch=entry.get('branch', 'master')
                )
                entries.append(e)
            return entries

    def save_gitsubtrees(self, repo_root, entries):
        path = os.path.join(repo_root, '.gitsubtrees')
        dict_entries = [{'path': e.path, 'url': e.url, 'branch': e.branch} for e in entries]
        with open(path, 'w') as f:
            yaml.dump(dict_entries, f, default_flow_style=False)

    def run_cmd(self, cmd_list):
        quiet = self.args.quiet
        interactive = self.args.interactive
        cmd_str = ' '.join(cmd_list)
        if not quiet:
            print(f"{ANSI_GRAY}{cmd_str}{ANSI_RESET}")
        if self.args.dry_run:
            return
        if interactive:
            resp = input(f"{ANSI_BOLD}Execute? [Y/n]{ANSI_RESET} ").strip().lower()
            if resp in ('n', 'no'):
                print(f"{ANSI_GRAY}Skipped.{ANSI_RESET}")
                return
        if quiet:
            subprocess.run(cmd_list, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            subprocess.run(cmd_list)

    def _check_working_tree_clean(self):
        result = subprocess.run(
            ['git', 'status', '--porcelain'],
            capture_output=True,
            text=True,
        )
        if result.stdout.strip():
            raise ValueError("working tree has modifications; commit or stash before pulling subtrees.", file=sys.stderr)

    def cmd_add(self):
        repo_root = self.get_repo_root()
        prefix = os.environ.get('GIT_PREFIX', '.')
        if self.args.folder:
            prefix = os.path.join(prefix, self.args.folder)
        url = self.args.url
        cmd_list = Subtree(prefix, url, 'master').get_squash_cmd('add')
        self.run_cmd(cmd_list)
        entries = self.load_gitsubtrees(repo_root)
        for e in entries:
            if e.path == prefix:
                print(f"{ANSI_GRAY}Entry already exists for path '{prefix}', not recording duplicate.{ANSI_RESET}", file=sys.stderr)
                return
        entry = Subtree(path=prefix, url=url, branch='master')
        entries.append(entry)
        self.save_gitsubtrees(repo_root, entries)

    def cmd_pull(self):
        repo_root = self.get_repo_root()
        self._check_working_tree_clean()
        entries = self.load_gitsubtrees(repo_root)
        if not entries:
            return
        if self.args.folder:
            prefix = os.environ.get('GIT_PREFIX', '.')
            prefix = os.path.join(prefix, self.args.folder)
            found = None
            for e in entries:
                if e.path == prefix:
                    found = e
                    break
            if not found:
                raise ValueError(f"No subtree found for path '{prefix}'")
            cmd_list = found.get_squash_cmd('pull')
            self.run_cmd(cmd_list)
        else:
            for e in entries:
                cmd_list = e.get_squash_cmd('pull')
                self.run_cmd(cmd_list)

    def execute(self):
        if self.args.command == 'add':
            self.cmd_add()
        elif self.args.command == 'pull':
            self.cmd_pull()

def main():
    parser = argparse.ArgumentParser(description="Manage git subtrees")
    parser.add_argument('-q', '--quiet', action='store_true', help='Suppress output of git commands')
    parser.add_argument('-i', '--interactive', action='store_true', help='Ask before executing external commands')
    parser.add_argument('-d', '--dry-run', action='store_true', help='Show commands but do not execute them')
    subparsers = parser.add_subparsers(dest='command', required=True, help='sub-command help')
    add_parser = subparsers.add_parser('add', help='Add a subtree')
    add_parser.add_argument('url', help='Repository URL')
    add_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (relative to current dir)')
    pull_parser = subparsers.add_parser('pull', help='Pull subtree updates')
    pull_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (optional; if omitted, pull all)')
    args = parser.parse_args()
    program = Program(args)
    program.execute()

if __name__ == '__main__':
    main()
