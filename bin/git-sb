#!/usr/bin/python3
import os
import sys
import argparse
import subprocess
import yaml

def get_repo_root():
    result = subprocess.run(
        ['git', 'rev-parse', '--show-toplevel'],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout.strip()

def load_gitsubtrees(repo_root):
    path = os.path.join(repo_root, '.gitsubtrees')
    if not os.path.exists(path):
        return []
    with open(path, 'r') as f:
        data = yaml.safe_load(f)
        if data is None:
            return []
        if not isinstance(data, list):
            print("Warning: .gitsubtrees is not a list; resetting", file=sys.stderr)
            return []
        valid = [e for e in data if isinstance(e, dict) and 'path' in e and 'url' in e]
        return valid

def save_gitsubtrees(repo_root, entries):
    path = os.path.join(repo_root, '.gitsubtrees')
    with open(path, 'w') as f:
        yaml.dump(entries, f, default_flow_style=False)

def run_cmd(cmd_list, args):
    quiet = args.quiet
    interactive = args.interactive
    cmd_str = ' '.join(cmd_list)
    print(f"\033[90m{cmd_str}\033[0m")
    if interactive:
        resp = input("Execute? [Y/n] ").strip().lower()
        if resp in ('n', 'no'):
            print("Skipped.")
            return
    if quiet:
        subprocess.run(cmd_list, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    else:
        subprocess.run(cmd_list)

def cmd_add(args):
    repo_root = get_repo_root()
    prefix = os.environ.get('GIT_PREFIX', '.')
    if args.folder:
        prefix = os.path.join(prefix, args.folder)
    url = args.url
    cmd_list = ["git", "subtree", "add", "--prefix", prefix, url, "master", "--squash"]
    run_cmd(cmd_list, args)
    entries = load_gitsubtrees(repo_root)
    for e in entries:
        if e['path'] == prefix:
            print(f"Entry already exists for path '{prefix}', not recording duplicate.", file=sys.stderr)
            return
    entry = {'path': prefix, 'url': url, 'branch': 'master'}
    entries.append(entry)
    save_gitsubtrees(repo_root, entries)

def cmd_pull(args):
    repo_root = get_repo_root()
    entries = load_gitsubtrees(repo_root)
    if not entries:
        print("No subtrees recorded in .gitsubtrees.")
        return
    if args.folder:
        prefix = os.environ.get('GIT_PREFIX', '.')
        prefix = os.path.join(prefix, args.folder)
        found = None
        for e in entries:
            if e['path'] == prefix:
                found = e
                break
        if not found:
            sys.exit(f"Error: No subtree found for path '{prefix}'")
        branch = found.get('branch', 'master')
        cmd_list = ["git", "subtree", "pull", "--prefix", found['path'], found['url'], branch, "--squash"]
        run_cmd(cmd_list, args)
    else:
        for e in entries:
            branch = e.get('branch', 'master')
            cmd_list = ["git", "subtree", "pull", "--prefix", e['path'], e['url'], branch, "--squash"]
            run_cmd(cmd_list, args)

def main():
    parser = argparse.ArgumentParser(description="Manage git subtrees")
    parser.add_argument('-q', '--quiet', action='store_true', help='Suppress output of git commands')
    parser.add_argument('-i', '--interactive', action='store_true', help='Ask before executing external commands')
    subparsers = parser.add_subparsers(dest='command', required=True, help='sub-command help')
    add_parser = subparsers.add_parser('add', help='Add a subtree')
    add_parser.add_argument('url', help='Repository URL')
    add_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (relative to current dir)')
    add_parser.set_defaults(func=cmd_add)
    pull_parser = subparsers.add_parser('pull', help='Pull subtree updates')
    pull_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (optional; if omitted, pull all)')
    pull_parser.set_defaults(func=cmd_pull)
    args = parser.parse_args()
    args.func(args)

if __name__ == '__main__':
    main()
