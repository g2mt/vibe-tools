#!/usr/bin/python3
import os
import sys
import argparse
import subprocess
import yaml
from dataclasses import dataclass, field, asdict

ANSI_GRAY = "\033[90m"
ANSI_RESET ="\033[0m"
ANSI_BOLD = "\033[1m"
ANSI_CYAN = "\033[36m"

@dataclass
class Subtree:
    path: str
    url: str
    branch: str = 'master'
    tags: list = field(default_factory=list)

    def get_squash_cmd(self, action, repo_root):
        # If attempting to pull but the subtree path does not exist, fall back to add
        if action == 'pull' and not os.path.isdir(os.path.join(repo_root, self.path)):
            action = 'add'
        path = self.path
        if path.startswith("./"):
            path=path[2:]
        return ["git","subtree",action,"--prefix",path,self.url,self.branch,"--squash","-m", f"Merge {self.url}"]

class Program:
    def __init__(self, args):
        self.args = args
        self.always_yes = False

    def get_repo_root(self):
        result = subprocess.run(
            ['git', 'rev-parse', '--show-toplevel'],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()

    def load_gitsubtrees(self, repo_root):
        path = os.path.join(repo_root, '.gitsubtrees')
        if not os.path.exists(path):
            return []
        with open(path, 'r') as f:
            data = yaml.safe_load(f)
            if data is None:
                return []
            if not isinstance(data, list):
                raise ValueError(f".gitsubtrees file must contain a list, got {type(data).__name__}")
            entries = []
            for entry in data:
                if not isinstance(entry, dict):
                    raise ValueError(f"Each entry must be a mapping, got {type(entry).__name__}: {entry}")
                if 'path' not in entry or 'url' not in entry:
                    raise ValueError(f"Each entry must have 'path' and 'url' keys, got {entry}")
                e = Subtree(
                    path=entry['path'],
                    url=entry['url'],
                    branch=entry.get('branch', 'master'),
                    tags=entry.get('tags', [])
                )
                entries.append(e)
            return entries

    def save_gitsubtrees(self, repo_root, entries):
        path = os.path.join(repo_root, '.gitsubtrees')
        dict_entries = [asdict(e) for e in entries]
        with open(path, 'w') as f:
            yaml.dump(dict_entries, f, default_flow_style=False)

    def run_cmd(self, cmd_list, cwd=None):
        quiet = self.args.quiet
        interactive = self.args.interactive
        cmd_str = ' '.join(cmd_list)
        if not quiet:
            print(f"{ANSI_GRAY}{cmd_str}{ANSI_RESET}")

        if self.args.dry_run:
            return

        if self.always_yes:
            pass
        elif interactive:
            resp = input(f"{ANSI_BOLD}Execute? (Y)es, (N)o, (A)ll: {ANSI_RESET} ").strip().lower()
            if resp in ('a', 'all'):
                self.always_yes = True
            elif resp in ('n', 'no'):
                print(f"{ANSI_GRAY}Skipped.{ANSI_RESET}")
                return

        if quiet:
            subprocess.run(cmd_list, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, cwd=cwd)
        else:
            subprocess.run(cmd_list, cwd=cwd)

    def _check_working_tree_clean(self):
        result = subprocess.run(
            ['git', 'status', '--porcelain'],
            capture_output=True,
            text=True,
        )
        if result.stdout.strip():
            raise ValueError("working tree has modifications; commit or stash before pulling subtrees.")

    def cmd_add(self):
        repo_root = self.get_repo_root()
        prefix = os.path.relpath(os.path.curdir, repo_root)
        if self.args.folder:
            prefix = os.path.join(prefix, self.args.folder)
        url = self.args.url
        cmd_list = Subtree(prefix, url, 'master').get_squash_cmd('add', repo_root)
        self.run_cmd(cmd_list, cwd=repo_root)
        entries = self.load_gitsubtrees(repo_root)
        for e in entries:
            if e.path == prefix:
                print(f"{ANSI_GRAY}Entry already exists for path '{prefix}', not recording duplicate.{ANSI_RESET}", file=sys.stderr)
                return
        entry = Subtree(path=prefix, url=url, branch='master')
        entries.append(entry)
        self.save_gitsubtrees(repo_root, entries)

    def cmd_mv(self):
        repo_root = self.get_repo_root()

        source = os.path.relpath(self.args.source, repo_root)
        dest = os.path.relpath(self.args.dest, repo_root)

        # 0. Assert source is an actual existing subtree in .gitsubtrees
        entries = self.load_gitsubtrees(repo_root)
        if not any(e.path == source for e in entries):
            raise ValueError(f"Path '{source}' is not registered as a subtree in .gitsubtrees")

        # 1. Find the last subtree split hash for the source path
        log_cmd = ["git", "log", "-1", "--grep", f"git-subtree-dir: {source}"]
        result = subprocess.run(log_cmd, capture_output=True, text=True, cwd=repo_root)
        
        split_hash = None
        for line in result.stdout.splitlines():
            if line.strip().startswith("git-subtree-split:"):
                split_hash = line.split(":")[1].strip()
                break
        
        if not split_hash:
            raise ValueError(f"Could not find subtree metadata for path '{source}'")

        # 2. git mv source dest
        self.run_cmd(["git", "mv", source, dest], cwd=repo_root)
        self.run_cmd(["git", "commit", "-m", f"Move subtree {source} to {dest}"], cwd=repo_root)

        # 3. Create empty commit with metadata
        msg = f"Reassign subtree dir from {source} to {dest}\n\ngit-subtree-dir: {dest}\ngit-subtree-split: {split_hash}"
        self.run_cmd(["git", "commit", "--allow-empty", "-m", msg], cwd=repo_root)

        # 4. Update .gitsubtrees
        found = False
        for e in entries:
            if e.path == source:
                e.path = dest
                found = True
                break
        
        if found:
            if not self.args.dry_run:
                self.save_gitsubtrees(repo_root, entries)
            self.run_cmd(["git", "add", ".gitsubtrees"], cwd=repo_root)
            self.run_cmd(["git", "commit", "-m", f"Update .gitsubtrees path {source} -> {dest}"], cwd=repo_root)

    def cmd_pull(self):
        repo_root = self.get_repo_root()
        self._check_working_tree_clean()
        entries = self.load_gitsubtrees(repo_root)
        if not entries:
            return
        # Filter by tags if provided
        tag_filter = self.args.tags
        if tag_filter:
            entries = [e for e in entries if e.tags and any(t in e.tags for t in tag_filter)]
        if self.args.folder:
            prefix = os.path.relpath(os.path.curdir, repo_root)
            prefix = os.path.join(prefix, self.args.folder)
            prefix = os.path.realpath(prefix)
            found = None
            for e in entries:
                if os.path.realpath(e.path) == prefix:
                    found = e
                    break
            if not found:
                raise ValueError(f"No subtree found for path '{prefix}'")
            cmd_list = found.get_squash_cmd('pull', repo_root)
            self.run_cmd(cmd_list, cwd=repo_root)
        else:
            for e in entries:
                cmd_list = e.get_squash_cmd('pull', repo_root)
                self.run_cmd(cmd_list, cwd=repo_root)

    def cmd_tags(self):
        repo_root = self.get_repo_root()
        entries = self.load_gitsubtrees(repo_root)
        if not entries:
            return
        # Build mapping tag -> list of paths
        tag_to_paths = {}
        for e in entries:
            for t in e.tags:
                tag_to_paths.setdefault(t, []).append(e.path)
        # Print each tag line
        for tag in sorted(tag_to_paths.keys()):
            paths = tag_to_paths[tag]
            paths_str = ", ".join(paths)
            print(f"{ANSI_CYAN}{tag}:{ANSI_RESET} {paths_str}")

    def execute(self):
        if self.args.command == 'add':
            self.cmd_add()
        elif self.args.command == 'pull':
            self.cmd_pull()
        elif self.args.command == 'mv':
            self.cmd_mv()
        elif self.args.command == 'tags':
            self.cmd_tags()

def main():
    parser = argparse.ArgumentParser(description="Manage git subtrees")
    parser.add_argument('-q', '--quiet', action='store_true', help='Suppress output of git commands')
    parser.add_argument('-i', '--interactive', action='store_true', help='Ask before executing external commands')
    parser.add_argument('-d', '--dry-run', action='store_true', help='Show commands but do not execute them')
    subparsers = parser.add_subparsers(dest='command', required=True, help='sub-command help')
    add_parser = subparsers.add_parser('add', help='Add a subtree')
    add_parser.add_argument('url', help='Repository URL')
    add_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (relative to current dir)')
    pull_parser = subparsers.add_parser('pull', help='Pull subtree updates')
    pull_parser.add_argument('folder', nargs='?', default=None, help='Subdirectory (optional; if omitted, pull all)')
    pull_parser.add_argument('-t', '--tag', action='append', dest='tags', default=None, help='Only pull subtrees with this tag (can be repeated)')
    mv_parser = subparsers.add_parser('mv', help='Move a subtree prefix')
    mv_parser.add_argument('source', help='Current subtree path')
    mv_parser.add_argument('dest', help='New subtree path')
    tags_parser = subparsers.add_parser('tags', help='Show list of tags and their directories')
    args = parser.parse_args()
    program = Program(args)
    program.execute()

if __name__ == '__main__':
    main()
