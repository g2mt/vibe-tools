#!/usr/bin/env python3

import pty
import os
import sys
import time
import select
import subprocess
import argparse

def main():
    parser = argparse.ArgumentParser(description="Wrapper for SSH command with PTY handling.")
    parser.add_argument('--input', required=True, help='Input string to send to SSH stdin.')
    parser.add_argument('ssh_args', nargs='+', help='Arguments for the SSH command.')

    args = parser.parse_args()

    input_string = args.input
    ssh_args = args.ssh_args

    # Spawn ssh with a temporary PTY
    master, slave = pty.openpty()
    ssh_process = subprocess.Popen(['ssh'] + ssh_args,
                                   stdin=slave,
                                   stdout=sys.stdout.fileno(),  # Redirect stdout to parent's stdout
                                   stderr=sys.stderr.fileno(), # Redirect stderr to parent's stderr
                                   close_fds=True)

    # Close the slave end of the PTY in the parent process
    os.close(slave)

    # Insert input string into PTY's stdin
    os.write(master, (input_string + '\n').encode())

    # Wait for 3 seconds
    time.sleep(3)

    # Replace PTY's stdin with real stdin
    # This is a bit tricky. We can't directly "replace" stdin of a running process.
    # The common approach is to use select to multiplex between the PTY's master
    # and the real stdin, and then write to the PTY's master.

    # Set stdin to non-blocking for select
    original_stdin_flags = os.fcntl(sys.stdin.fileno(), os.F_GETFL)
    os.fcntl(sys.stdin.fileno(), os.F_SETFL, original_stdin_flags | os.O_NONBLOCK)

    try:
        while True:
            rlist, _, _ = select.select([sys.stdin.fileno(), master], [], [])

            if sys.stdin.fileno() in rlist:
                data = os.read(sys.stdin.fileno(), 1024)
                if not data:
                    break  # EOF on stdin
                os.write(master, data)

            if master in rlist:
                data = os.read(master, 1024)
                if not data:
                    break  # EOF on PTY
                sys.stdout.buffer.write(data)
                sys.stdout.flush()

            # Check if ssh process has exited
            if ssh_process.poll() is not None:
                break

    finally:
        # Restore original stdin flags
        os.fcntl(sys.stdin.fileno(), os.F_SETFL, original_stdin_flags)
        # Close the master end of the PTY
        os.close(master)
        # Wait for the ssh process to finish
        ssh_process.wait()

if __name__ == '__main__':
    main()

