#!/usr/bin/env python3

import argparse
import os
import pty
import select
import subprocess
import sys
import time
import threading
import termios
import tty


def main():
    parser = argparse.ArgumentParser(description='SSH command wrapper with PTY')
    parser.add_argument('--input', required=True, help='Input string to send to SSH')
    parser.add_argument('ssh_args', nargs='+', help='SSH arguments')

    args = parser.parse_args()

    # Save original terminal settings
    original_stdin_attrs = termios.tcgetattr(sys.stdin.fileno())
    
    # Disable canonical mode and set VMIN=1, VTIME=0
    tty.setraw(sys.stdin.fileno())
    new_attrs = termios.tcgetattr(sys.stdin.fileno())
    new_attrs[6][termios.VMIN] = 1
    new_attrs[6][termios.VTIME] = 0
    termios.tcsetattr(sys.stdin.fileno(), termios.TCSANOW, new_attrs)

    # Create a PTY pair
    master_fd, slave_fd = pty.openpty()

    try:
        # Spawn SSH process with the slave PTY as stdin/stdout/stderr
        ssh_process = subprocess.Popen(
            ['ssh'] + args.ssh_args,
            stdin=slave_fd,
            stdout=slave_fd,
            stderr=slave_fd,
            preexec_fn=os.setsid
        )

        # Close slave fd in parent process
        os.close(slave_fd)

        # Start a thread to wait for output then send input
        def send_input_after_output():
            # Wait for any output to be received first
            try:
                ready, _, _ = select.select([master_fd], [], [], 10)  # 10 second timeout
                if ready:
                    # Read and discard initial output (like prompts)
                    os.read(master_fd, 1024)

                # Now send the input string
                input_bytes = (args.input + '\r\n').encode('utf-8')
                os.write(master_fd, input_bytes)
            except OSError:
                pass

        input_thread = threading.Thread(target=send_input_after_output, daemon=True)
        input_thread.start()

        # Start a thread to copy PTY output to stdout
        def copy_output():
            while True:
                try:
                    ready, _, _ = select.select([master_fd], [], [], 0.1)
                    if ready:
                        data = os.read(master_fd, 1024)
                        if not data:
                            break
                        sys.stdout.buffer.write(data)
                        sys.stdout.buffer.flush()
                except OSError:
                    break

        output_thread = threading.Thread(target=copy_output, daemon=True)
        output_thread.start()

        # Now pipe stdin to the PTY
        def copy_stdin():
            while True:
                try:
                    ready, _, _ = select.select([sys.stdin], [], [], 0.1)
                    if ready:
                        data = sys.stdin.buffer.read(1)
                        if not data:
                            break
                        os.write(master_fd, data)
                except (OSError, KeyboardInterrupt):
                    break

        stdin_thread = threading.Thread(target=copy_stdin, daemon=True)
        stdin_thread.start()

        # Wait for SSH process to complete
        ssh_process.wait()

    except KeyboardInterrupt:
        # Handle Ctrl+C gracefully
        if ssh_process.poll() is None:
            ssh_process.terminate()
    finally:
        # Restore original terminal settings
        try:
            termios.tcsetattr(sys.stdin.fileno(), termios.TCSANOW, original_stdin_attrs)
        except termios.error:
            pass
        
        # Clean up
        try:
            os.close(master_fd)
        except OSError:
            pass


if __name__ == '__main__':
    main()
