#!/usr/bin/env python3
import sys

def parse_commands(input_string):
    in_single_quote = False
    in_double_quote = False
    escaped = False
    
    commands = []
    current_cmd = ""
    
    i = 0
    n = len(input_string)
    
    while i < n:
        char = input_string[i]
        
        if char == '\\':
            if in_single_quote:
                current_cmd += char
                i += 1
            else:
                if escaped:
                    current_cmd += char
                    escaped = False
                    i += 1
                else:
                    current_cmd += char
                    escaped = True
                    i += 1
            continue
            
        if escaped:
            current_cmd += char
            escaped = False
            i += 1
            continue
            
        if char == "'":
            if in_double_quote:
                current_cmd += char
            else:
                in_single_quote = not in_single_quote
                current_cmd += char
            i += 1
            continue
            
        if char == '"':
            if in_single_quote:
                current_cmd += char
            else:
                in_double_quote = not in_double_quote
                current_cmd += char
            i += 1
            continue
            
        if not in_single_quote:
            if char == '`':
                return None
            if char == '$' and i + 1 < n and input_string[i+1] == '(':
                return None
            if char == '#':
                if not current_cmd or current_cmd[-1] in ' \t\r\n':
                    while i < n and input_string[i] != '\n':
                        i += 1
                    continue
                    
        if not in_single_quote and not in_double_quote:
            if char in '<>()':
                return None
                
            if char == '&':
                if i + 1 < n and input_string[i+1] == '&':
                    commands.append(current_cmd)
                    current_cmd = ""
                    i += 2
                    continue
                else:
                    return None
                    
            if char == '|':
                if i + 1 < n and input_string[i+1] == '|':
                    commands.append(current_cmd)
                    current_cmd = ""
                    i += 2
                    continue
                else:
                    return None
                    
            if char == ';':
                commands.append(current_cmd)
                current_cmd = ""
                i += 1
                continue
                
            if char == '\n':
                commands.append(current_cmd)
                current_cmd = ""
                i += 1
                continue
                
        current_cmd += char
        i += 1
        
    if in_single_quote or in_double_quote or escaped:
        return None
        
    commands.append(current_cmd)
    
    result = []
    keywords = {'if', 'then', 'elif', 'else', 'fi', 'for', 'while', 'until', 'do', 'done', 'case', 'esac', 'select', 'function'}
    
    for cmd in commands:
        stripped = cmd.strip()
        if not stripped:
            continue
            
        args = tokenize_arguments(stripped)
        if args and args[0] in keywords:
            return None
            
        result.append(stripped)
        
    return result

def tokenize_arguments(cmd_str):
    in_single_quote = False
    in_double_quote = False
    escaped = False
    
    args = []
    current_arg = ""
    
    i = 0
    n = len(cmd_str)
    
    while i < n:
        char = cmd_str[i]
        
        if char == '\\':
            if in_single_quote:
                current_arg += char
                i += 1
            else:
                if escaped:
                    current_arg += char
                    escaped = False
                    i += 1
                else:
                    current_arg += char
                    escaped = True
                    i += 1
            continue
            
        if escaped:
            current_arg += char
            escaped = False
            i += 1
            continue
            
        if char == "'":
            if in_double_quote:
                current_arg += char
            else:
                in_single_quote = not in_single_quote
                current_arg += char
            i += 1
            continue
            
        if char == '"':
            if in_single_quote:
                current_arg += char
            else:
                in_double_quote = not in_double_quote
                current_arg += char
            i += 1
            continue
            
        if not in_single_quote and not in_double_quote and char in ' \t\r\n':
            if current_arg:
                args.append(current_arg)
                current_arg = ""
            i += 1
            continue
            
        current_arg += char
        i += 1
        
    if current_arg:
        args.append(current_arg)
        
    return args

def main():
    if len(sys.argv) > 1:
        input_data = sys.argv[1]
    else:
        input_data = sys.stdin.read()
        
    res = parse_commands(input_data)
    if res is None:
        sys.exit(1)
        
    for cmd in res:
        print(cmd)

if __name__ == '__main__':
    main()
