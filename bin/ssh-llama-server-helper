#!/usr/bin/python3

from dataclasses import dataclass
import argparse
import logging
import subprocess
import sys
import re
import shlex
import signal
import threading
import time
import requests
import os
import atexit
from typing import List, Optional, Tuple

WAIT_SECS = 3

@dataclass
class ExistingLlamaServer:
    port: str
    pid: str

@dataclass
class ProgramData:
    host: str
    system: str
    forwarded_port: str
    server_args: List[str]
    model: Optional[str] = None
    slot_save_path: Optional[str] = None
    process: Optional[subprocess.Popen] = None
    threads: List[threading.Thread] = None
    exit_requested: bool = False
    binary_name: Optional[str] = None

    def __post_init__(self):
        if self.threads is None:
            self.threads = []
        if self.server_args:
            self.binary_name = os.path.basename(self.server_args[0])

    #### SSH Commands

    def run_ssh_command(self, cmd: str, timeout: int = 5) -> subprocess.CompletedProcess:
        """Run an SSH command with logging"""
        logging.info(f"Running SSH command on {self.host}: {cmd}")
        return subprocess.run(['ssh', self.host, cmd],
                            capture_output=True,
                            text=True,
                            timeout=timeout)

    #### System detection

    @staticmethod
    def detect_system(host: str) -> str:
        """Detect if remote system is Windows or Unix-like"""
        try:
            result = subprocess.run(['ssh', host, 'echo %OS%'],
                                  capture_output=True,
                                  text=True,
                                  timeout=10)
            if 'Windows' in result.stdout:
                return 'windows'
        except Exception as e:
            raise RuntimeError(f"Failed to detect system on {host}: {e}")
        return 'unix'

    #### Remote process management

    def check_running_process(self, model: Optional[str]) -> Optional[ExistingLlamaServer]:
        """Check if the binary is running with the specified model"""
        if self.system == 'windows':
            cmd = f'wmic process where "name like \'{self.binary_name}%\'" get processid,commandline /format:csv'
            try:
                result = self.run_ssh_command(cmd)
                if self.binary_name in result.stdout:
                    # Split output into lines and check each one
                    lines = result.stdout.strip().split('\n')
                    for line in lines:
                        if self.binary_name in line:
                            if model is None or model in line:
                                port_match = re.search(r'--port\s+(\d+)', line)
                                pid_match = re.search(r',(\d+)$', line)
                                if port_match and pid_match:
                                    return ExistingLlamaServer(port=port_match.group(1), pid=pid_match.group(1))
            except Exception as e:
                logging.warning(f"Error checking running process on Windows: {e}")
        else:
            # Use pgrep to find processes and ps to get command line
            cmd = f"pgrep -f '{self.binary_name}$' | xargs -I {{}} ps -p {{}} -o pid,args -h"
            try:
                result = self.run_ssh_command(cmd)
                if result.returncode == 0 and result.stdout.strip():
                    # Split output into lines and check each one
                    lines = result.stdout.strip().split('\n')
                    for line in lines:
                        line = line.strip()
                        if line and self.binary_name in line:
                            parts = line.split(maxsplit=1)
                            if len(parts) == 2:
                                pid, args = parts
                                if model is None or model in args:
                                    port_match = re.search(r'--port\s+(\d+)', args)
                                    if port_match:
                                        return ExistingLlamaServer(port=port_match.group(1), pid=pid)
            except Exception as e:
                logging.warning(f"Error checking running process on Unix: {e}")
        return None

    def kill_existing_process(self, server: ExistingLlamaServer) -> None:
        """Kill existing server process"""
        if self.system == 'windows':
            cmd = f'taskkill /F /PID {server.pid}'
        else:
            cmd = f"kill {server.pid}"

        try:
            self.run_ssh_command(cmd)
        except Exception as e:
            logging.warning(f"Failed to kill process on {self.host}: {e}")

    #### HTTP Requests

    def save_model_cache(self) -> str:
        """Save model cache to slot_save_path"""
        if not (self.slot_save_path and self.model):
            return "Error: No model or slot_save_path specified"

        model_basename = os.path.basename(self.model)
        cache_file = f"{model_basename}.bin"
        save_url = f"http://localhost:{self.forwarded_port}/slots/0?action=save"
        try:
            response = requests.post(save_url, json={"filename": cache_file})
            return response.text
        except Exception as e:
            return f'{{"error": "{str(e)}"}}'

    def restore_model_cache(self) -> str:
        """Restore model cache from slot_save_path if available"""
        if not (self.slot_save_path and self.model):
            return "Error: No model or slot_save_path specified"

        model_basename = os.path.basename(self.model)
        cache_file = f"{model_basename}.bin"

        if self.system == 'windows':
            check_cmd = f"if exist \"{self.slot_save_path}/{cache_file}\" (echo exists)"
        else:
            check_cmd = f"test -f \"{self.slot_save_path}/{cache_file}\" && echo exists"

        try:
            result = self.run_ssh_command(check_cmd)
            if 'exists' in result.stdout:
                restore_url = f"http://localhost:{self.forwarded_port}/slots/0?action=restore"
                response = requests.post(restore_url, json={"filename": cache_file})
                return response.text
            return '{"error":"No cache file found"}'
        except Exception as e:
            return f'{{"error": "{str(e)}"}}'

    def check_health(self) -> bool:
        """Check server health and restore model if needed"""
        health_url = f"http://localhost:{self.forwarded_port}/health"

        while True:
            try:
                response = requests.get(health_url, timeout=5)
                if response.status_code == 200:
                    return True
            except:
                pass
            time.sleep(5)

        return False

    #### SSH Tunnel

    def start_ssh_tunnel(self, close_if_not_running: bool = False) -> bool:
        """Start the SSH tunnel process"""
        existing_server = self.check_running_process(self.model)
        if close_if_not_running and not existing_server:
            return False

        if existing_server:
            logging.info(f"Found existing server running on port {existing_server.port} (pid {existing_server.pid})")
            ssh_cmd = ['ssh', '-N', '-o', 'ServerAliveInterval=3600', '-L', f'{self.forwarded_port}:127.0.0.1:{existing_server.port}', self.host]

            logging.info(f"Starting SSH tunnel: {ssh_cmd}")
            self.process = subprocess.Popen(ssh_cmd)
        else:
            logging.info("No existing server found, starting new instance")

            server_args_str = " ".join(self.server_args)

            ssh_cmd = ['ssh', '-L', f'{self.forwarded_port}:127.0.0.1:{self.forwarded_port}',
                      self.host, server_args_str]

            logging.info(f"Starting SSH tunnel with command: {ssh_cmd}")
            self.process = subprocess.Popen(ssh_cmd)

        return True

    def cleanup(self) -> None:
        """Clean up all resources associated with program data"""
        logging.info("Cleaning up program data")

        # Kill the remote server process
        existing_server = self.check_running_process(self.model)
        if existing_server:
            logging.info(f"Killing remote server process: {self.binary_name} (pid {existing_server.pid})")
            self.kill_existing_process(existing_server)

        # Terminate the SSH tunnel process
        self.force_exit_ssh_process()

        # Clean up all threads
        for thread in self.threads:
            if thread.is_alive():
                logging.debug(f"Waiting for thread {thread.name} to complete")
                thread.join(timeout=1)

    def force_exit_ssh_process(self) -> None:
        """Force kill the SSH process immediately (used on SIGUSR1)"""
        if self.process:
            logging.info("Terminating SSH tunnel process")
            try:
                if self.process.poll() is not None:
                    logging.info("Terminated")
                    self.process = None
                    return
                self.process.terminate()
                self.process.wait(timeout=3)
                self.process = None
                return
            except Exception as e:
                logging.error(f"Error terminating process, force killing: {e}")
                try:
                    self.process.kill()
                except:
                    pass
            self.process = None

#### CLI utils

class ReloadTunnelException(Exception):
    pass

def extract_arg(args: List[str], flag: str) -> Optional[str]:
    """Extract argument value following specified flag

    Args:
        args: List of command line arguments
        flag: The flag to look for (e.g. '-m' or '--port')

    Returns:
        The extracted string value, or None if not found
    """
    for i, arg in enumerate(args):
        if arg == flag and i + 1 < len(args):
            return args[i + 1]
    return None


def main() -> None:
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s - %(levelname)s - %(message)s'
    )
    logging.info(f"(ssh-llama-server-helper pid={os.getpid()})")

    parser = argparse.ArgumentParser(description='SSH llama-server helper')
    parser.add_argument('--host', help='SSH host')
    parser.add_argument('--system', nargs='?', const='', default='',
                        choices=['windows', 'unix', ''],
                        help='Remote system type (windows/unix). Default: auto-detect')
    # rest of the args (server_args) are parsed by parser.parse_known_args

    args, server_args = parser.parse_known_args()

    assert args.host is not None
    host: str = args.host
    logging.info(f"Starting helper for host: {host}")

    forwarded_port = extract_arg(server_args, '--port')
    if not forwarded_port:
        logging.error("No --port argument found in llama-server arguments")
        sys.exit(1)

    system = args.system if args.system else ProgramData.detect_system(host)
    program_data = ProgramData(
        host=host,
        system=system,
        forwarded_port=forwarded_port,
        model=extract_arg(server_args, '-m'),
        slot_save_path=extract_arg(server_args, '--slot-save-path'),
        server_args=server_args,
    )

    logging.info(f"Forwarding port: {program_data.forwarded_port}")
    logging.info(f"Detected system type: {program_data.system}")

    # Register cleanup function
    atexit.register(program_data.cleanup)

    def handle_sigterm(signum, frame):
        """Handle SIGTERM by cleaning up and exiting"""
        logging.info("Received SIGTERM, cleaning up")
        program_data.cleanup()
        sys.exit(0)

    signal.signal(signal.SIGTERM, handle_sigterm)

    def handle_sigusr1(signum, frame):
        """Handle SIGUSR1 by force exiting SSH process and reloading tunnel"""
        logging.info("Received SIGUSR1, force exiting SSH process and reloading tunnel")
        raise ReloadTunnelException() # raises error in main while loop

    signal.signal(signal.SIGUSR1, handle_sigusr1)

    program_data.start_ssh_tunnel()

    # Restore cache thread

    if program_data.model and program_data.slot_save_path:
        def check_health_and_restore_cache():
            if program_data.check_health():
                program_data.restore_model_cache()
        restore_cache_thread = threading.Thread(
            target=check_health_and_restore_cache,
            daemon=True
        )
        restore_cache_thread.start()
        program_data.threads.append(restore_cache_thread)

    # Main loop: restart SSH tunnel automatically unless exit is requested
    while True:
        try:
            time.sleep(1)
            logging.info("Waiting for SSH tunnel process to complete")
            if program_data.process is None:
                raise RuntimeError("process canceled")
            program_data.process.wait()
            logging.info("SSH tunnel process completed")

            if program_data.exit_requested:
                return
            program_data.start_ssh_tunnel(True)

        except ReloadTunnelException:
            program_data.force_exit_ssh_process()
            if not program_data.exit_requested:
                logging.info("Attempting to restart SSH tunnel after error")
                try:
                    if not program_data.start_ssh_tunnel(True):
                        return
                    continue
                except Exception as restart_error:
                    logging.error(f"Failed to restart SSH tunnel: {restart_error}")
                    sys.exit(1)


if __name__ == '__main__':
    main()
