#!/usr/bin/python3
import csv
import io
import os
import sys
import argparse
import subprocess
import tempfile
from pathlib import Path

ANSI_GRAY = "\033[90m"
ANSI_RESET = "\033[0m"
ANSI_RED = "\033[91m"
ANSI_GREEN = "\033[92m"


def get_config_path():
    xdg_config = os.environ.get("XDG_CONFIG_HOME", os.path.join(Path.home(), ".config"))
    return os.path.join(xdg_config, "gitbackup.txt")


def run_cmd(cmd_list, cwd=None, capture=False):
    kwargs = {}
    if capture:
        kwargs["capture_output"] = True
        kwargs["text"] = True
    try:
        return subprocess.run(cmd_list, cwd=cwd, check=True, **kwargs)
    except subprocess.CalledProcessError:
        return None


def parse_refs(content):
    refs = {}
    reader = csv.reader(io.StringIO(content))
    for row in reader:
        if row and len(row) >= 2:
            refs[row[0]] = row[1]
    return refs


def format_refs(refs):
    buf = io.StringIO()
    writer = csv.writer(buf)
    for branch in sorted(refs):
        writer.writerow([branch, refs[branch]])
    return buf.getvalue()


def _tmpfile_path(suffix=""):
    fd, path = tempfile.mkstemp(suffix=suffix)
    os.close(fd)
    return path


class Program:
    def __init__(self, args):
        self.args = args
        self.config_path = get_config_path()

        result = run_cmd(
            ["git", "config", "--get", "git-backup-rclone.remote-path"],
            capture=True,
        )
        if not result or not result.stdout.strip():
            print(
                f"{ANSI_RED}Error:{ANSI_RESET} "
                f"git config 'git-backup-rclone.remote-path' not set",
                file=sys.stderr,
            )
            print("  Set it with:", file=sys.stderr)
            print(
                "    git config --global git-backup-rclone.remote-path 'remote:/path/'",
                file=sys.stderr,
            )
            sys.exit(1)
        self.remote_path = result.stdout.strip().rstrip("/")

    # ── config CSV helpers ────────────────────────────────────────────

    def _read_config(self):
        if not os.path.exists(self.config_path):
            return []
        entries = []
        with open(self.config_path, "r", newline="") as f:
            for row in csv.reader(f):
                if row:
                    entries.append((row[0], row[1] if len(row) > 1 else ""))
        return entries

    def _write_config(self, entries):
        os.makedirs(os.path.dirname(self.config_path), exist_ok=True)
        with open(self.config_path, "w", newline="") as f:
            writer = csv.writer(f)
            for path, branch in entries:
                writer.writerow([path, branch])

    # ── git helpers ───────────────────────────────────────────────────

    @staticmethod
    def _git_dir(repo):
        result = run_cmd(["git", "rev-parse", "--git-dir"], cwd=repo, capture=True)
        if not result or not result.stdout.strip():
            return os.path.join(repo, ".git")
        return result.stdout.strip()

    @staticmethod
    def _resolve_git_repo(path):
        target = os.path.abspath(path)
        result = run_cmd(["git", "rev-parse", "--show-toplevel"], cwd=target, capture=True)
        if not result or not result.stdout.strip():
            print(f"{ANSI_RED}Error:{ANSI_RESET} '{target}' is not inside a git repository", file=sys.stderr)
            sys.exit(1)
        repo = result.stdout.strip()

        branch_result = run_cmd(
            ["git", "rev-parse", "--abbrev-ref", "HEAD"], cwd=repo, capture=True
        )
        if not branch_result or not branch_result.stdout.strip():
            print(f"{ANSI_RED}Error:{ANSI_RESET} could not determine current branch", file=sys.stderr)
            sys.exit(1)
        return repo, branch_result.stdout.strip()

    # ── refs cache ────────────────────────────────────────────────────

    def _read_cache(self, repo):
        cache_file = os.path.join(repo, ".git", "rclone-refs")
        if os.path.exists(cache_file):
            with open(cache_file, "r") as f:
                return parse_refs(f.read())
        return None

    def _write_cache(self, repo, refs):
        cache_file = os.path.join(repo, ".git", "rclone-refs")
        print(cache_file)
        with open(cache_file, "w", newline="") as f:
            f.write(format_refs(refs))

    def _get_remote_refs(self, repo, force=False):
        if not force:
            cached = self._read_cache(repo)
            if cached is not None:
                return cached

        refs_path = f"{self.remote_path}/{os.path.basename(repo)}/refs"
        try:
            result = subprocess.run(
                    ["rclone", "cat", refs_path],
                capture_output=True,
                text=True,
            )
            if result.returncode == 0 and result.stdout.strip():
                refs = parse_refs(result.stdout)
                self._write_cache(repo, refs)
                return refs
        except Exception:
            pass

        self._write_cache(repo, {})
        return {}

    # ── commands ──────────────────────────────────────────────────────

    def cmd_add(self):
        target, branch = self._resolve_git_repo(self.args.directory)

        entries = self._read_config()
        if any(p == target for p, _ in entries):
            print(f"'{target}' already in backup list", file=sys.stderr)
            return

        entries.append((target, branch))
        self._write_config(entries)
        print(f"{ANSI_GREEN}Added{ANSI_RESET} {target} (branch: {branch})")

    def cmd_sync(self, repo=None, branch=None):
        if repo is None:
            repo, branch = self._resolve_git_repo(self.args.directory)

        if not branch:
            print(f"{ANSI_RED}SKIP{ANSI_RESET} {repo}  (no branch specified)")
            return

        repo_basename = os.path.basename(repo)

        if self.args.pull_refs:
            self._get_remote_refs(repo=repo, force=True)
            print(f"{ANSI_GREEN}PULLED{ANSI_RESET} refs for {repo} ({branch})")
            return

        head_commit = run_cmd(["git", "rev-parse", branch], cwd=repo, capture=True)
        if not head_commit or not head_commit.stdout.strip():
            print(f"{ANSI_RED}SKIP{ANSI_RESET} {repo}  (branch '{branch}' not found)")
            return

        head_commit = head_commit.stdout.strip()
        remote_refs = self._get_remote_refs(repo=repo, force=self.args.force)
        remote_commit = remote_refs.get(branch)

        if remote_commit == head_commit:
            tag = "FORCE" if self.args.force else "OK"
            color = ANSI_GRAY if self.args.force else ANSI_GREEN
            print(f"{color}{tag}{ANSI_RESET}   {repo} ({branch})")
            if not self.args.force:
                return

        filename = f"{branch}.gzip"
        dest_dir = f"{self.remote_path}/{repo_basename}"
        dest_path = f"{dest_dir}/{filename}"

        print(f"{ANSI_GRAY}EXPORT{ANSI_RESET} {repo} ({branch}) -> {dest_dir}/{filename}")

        tmp_path = _tmpfile_path(suffix=".gzip")
        try:
            with open(tmp_path, "wb") as f:
                proc1 = subprocess.Popen(
                    ["git", "fast-export", "--all"],
                    cwd=repo,
                    stdout=subprocess.PIPE,
                )
                proc2 = subprocess.Popen(
                    ["gzip"],
                    stdin=proc1.stdout,
                    stdout=f,
                )
                proc1.stdout.close()
                ret2 = proc2.wait()
                ret1 = proc1.wait()
                if ret1 != 0 or ret2 != 0:
                    print(f"{ANSI_RED}ERROR{ANSI_RESET} {repo}  (export/gzip failed)")
                    return

            upload = run_cmd(["rclone", "copyto", tmp_path, dest_path])
            if not upload:
                print(f"{ANSI_RED}ERROR{ANSI_RESET} {repo}  (rclone copy failed)")
                return

            remote_refs[branch] = head_commit

            tmp_refs_path = _tmpfile_path()
            try:
                with open(tmp_refs_path, "w", newline="") as f:
                    f.write(format_refs(remote_refs))
                refs_path = f"{self.remote_path}/{repo_basename}/refs"
                run_cmd(["rclone", "copyto", tmp_refs_path, refs_path])
            finally:
                if os.path.exists(tmp_refs_path):
                    os.unlink(tmp_refs_path)

            self._write_cache(repo, remote_refs)

            print(f"{ANSI_GREEN}DONE{ANSI_RESET}  {repo} ({branch})")

        finally:
            if os.path.exists(tmp_path):
                os.unlink(tmp_path)

    def cmd_sync_all(self):
        entries = self._read_config()
        if not entries:
            print(f"Backup list not found at {self.config_path}", file=sys.stderr)
            return

        for repo, branch in entries:
            self.cmd_sync(repo=repo, branch=branch)

    # ── dispatch ──────────────────────────────────────────────────────

    def execute(self):
        if self.args.command == "add":
            self.cmd_add()
        elif self.args.command == "sync":
            self.cmd_sync()
        elif self.args.command == "sync-all":
            self.cmd_sync_all()


def main():
    parser = argparse.ArgumentParser(
        description="Backup git repos to rclone remote via fast-export"
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    add_parser = subparsers.add_parser("add", help="Add a directory to the backup list")
    add_parser.add_argument("directory", nargs="?", default=".",
                            help="Directory to add (default: current dir)")

    sync_parser = subparsers.add_parser("sync", help="Export current repo and upload to rclone remote")
    sync_parser.add_argument("directory", nargs="?", default=".",
                             help="Directory to sync (default: current dir)")
    sync_parser.add_argument("-f", "--force", action="store_true",
                             help="Force upload even if remote ref matches")
    sync_parser.add_argument("--pull-refs", action="store_true",
                             help="Only pull remote refs to local cache, no export/upload")

    sync_all_parser = subparsers.add_parser("sync-all", help="Export all repos from backup list")
    sync_all_parser.add_argument("-f", "--force", action="store_true",
                                 help="Force upload even if remote ref matches")
    sync_all_parser.add_argument("--pull-refs", action="store_true",
                                 help="Only pull remote refs to local cache, no export/upload")

    args = parser.parse_args()
    Program(args).execute()


if __name__ == "__main__":
    main()
