#!/usr/bin/python3
import argparse
import json
import time
import sys
from http.server import HTTPServer, BaseHTTPRequestHandler
from http import HTTPStatus

THINKING_TOKENS = [" I", " am", " thinking"]


def make_handler(max_tokens, tps):
    _max_tokens = max_tokens
    _sleep_time = 1.0 / tps
    class OpenAIHandler(BaseHTTPRequestHandler):
        max_tokens = _max_tokens
        sleep_time = _sleep_time

        # ---- helpers ----

        def _cors_headers(self):
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Access-Control-Allow-Methods", "GET, POST, OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type, Authorization")

        def _send_json(self, status, data):
            body = json.dumps(data, ensure_ascii=False).encode("utf-8")
            self.send_response(status)
            self._cors_headers()
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)

        def _read_body(self):
            length = int(self.headers.get("Content-Length", 0))
            return self.rfile.read(length)

        def _model_list(self):
            return {
                "object": "list",
                "data": [
                    {
                        "id": "mock-thinking",
                        "object": "model",
                        "created": int(time.time()),
                        "owned_by": "mock",
                    }
                ],
            }

        def _generate(self, n):
            for i in range(n):
                yield THINKING_TOKENS[i % len(THINKING_TOKENS)]
                time.sleep(self.sleep_time)

        # ---- HTTP verbs ----

        def do_OPTIONS(self):
            self.send_response(HTTPStatus.NO_CONTENT)
            self._cors_headers()
            self.end_headers()

        def do_GET(self):
            if self.path == "/v1/models":
                self._send_json(200, self._model_list())
            elif self.path == "/" or self.path == "/health":
                self._send_json(200, {"status": "ok", "model": "mock-thinking"})
            else:
                self._send_json(404, {"error": "not found"})

        def do_POST(self):
            if self.path not in ("/v1/chat/completions", "/chat/completions"):
                self._send_json(404, {"error": "not found"})
                return

            body = self._read_body()
            try:
                data = json.loads(body) if body else {}
            except json.JSONDecodeError:
                self._send_json(400, {"error": "invalid JSON"})
                return

            stream = data.get("stream", False)

            if stream:
                self._handle_stream(data)
            else:
                self._handle_non_stream(data)

        # ---- streaming ----

        def _handle_stream(self, data):
            n = min(data.get("max_tokens", self.max_tokens), self.max_tokens)

            self.send_response(HTTPStatus.OK)
            self._cors_headers()
            self.send_header("Content-Type", "text/event-stream")
            self.send_header("Cache-Control", "no-cache")
            self.send_header("Connection", "keep-alive")
            self.send_header("X-Accel-Buffering", "no")
            self.end_headers()

            rid = f"chatcmpl-{int(time.time())}"
            ts = int(time.time())

            def sse(obj):
                return f"data: {json.dumps(obj, ensure_ascii=False)}\n\n".encode()

            try:
                # role-assistant preamble
                self.wfile.write(sse({
                    "id": rid, "object": "chat.completion.chunk", "created": ts,
                    "model": "mock-thinking",
                    "choices": [{"index": 0, "delta": {"role": "assistant"}, "finish_reason": None}],
                }))
                self.wfile.flush()

                for token in self._generate(n):
                    self.wfile.write(sse({
                        "id": rid, "object": "chat.completion.chunk", "created": ts,
                        "model": "mock-thinking",
                        "choices": [{"index": 0, "delta": {"content": token}, "finish_reason": None}],
                    }))
                    self.wfile.flush()
                # finish
                self.wfile.write(sse({
                    "id": rid, "object": "chat.completion.chunk", "created": ts,
                    "model": "mock-thinking",
                    "choices": [{"index": 0, "delta": {}, "finish_reason": "stop"}],
                }))
                self.wfile.write(b"data: [DONE]\n\n")
                self.wfile.flush()

            except (BrokenPipeError, ConnectionResetError, OSError):
                pass  # client disconnected

        # ---- non-streaming ----

        def _handle_non_stream(self, data):
            n = min(data.get("max_tokens", self.max_tokens), self.max_tokens)
            content = "".join(self._generate(n))

            self._send_json(200, {
                "id": f"chatcmpl-{int(time.time())}",
                "object": "chat.completion",
                "created": int(time.time()),
                "model": "mock-thinking",
                "choices": [{
                    "index": 0,
                    "message": {"role": "assistant", "content": content},
                    "finish_reason": "stop",
                }],
                "usage": {
                    "prompt_tokens": 0,
                    "completion_tokens": n,
                    "total_tokens": n,
                },
            })

        # ---- silence default logging ----

        def log_message(self, fmt, *args):
            pass

    return OpenAIHandler


def main():
    parser = argparse.ArgumentParser(
        description="Mock OpenAI-compatible server that serves the 'mock-thinking' model."
    )
    parser.add_argument(
        "-b",
        dest="bind",
        default="127.0.0.1",
        help="Address to bind to (default: 127.0.0.1)",
    )
    parser.add_argument(
        "port",
        nargs="?",
        type=int,
        default=8912,
        help="Port to listen on (default: 8912)",
    )
    parser.add_argument(
        "--max-tokens",
        type=int,
        default=1000,
        help="Maximum number of thinking tokens to generate (default: 1000)",
    )
    parser.add_argument(
        "--tps",
        type=float,
        default=50.0,
        help="Tokens per second generation rate (default: 50.0)",
    )
    args = parser.parse_args()

    server = HTTPServer((args.bind, args.port), make_handler(args.max_tokens, args.tps))
    print(f"mock-openai-server listening on {args.bind}:{args.port}", file=sys.stderr)
    print(f"  model: mock-thinking  max_tokens: {args.max_tokens}  tps: {args.tps}", file=sys.stderr)
    print(f"  endpoints: GET  /v1/models  |  POST /v1/chat/completions", file=sys.stderr)

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("", file=sys.stderr)
        server.shutdown()


if __name__ == "__main__":
    main()
